  "keyFeatures": [
    "27 data modules covering people, locations, dates, finance, commerce, and more",
    "70+ supported locales for generating region-specific realistic data",
    "Reproducible results via seeding with Mersenne Twister PRNG",
    "Tree-shakeable locale-specific imports for optimized bundle size",
    "TypeScript-first with full type definitions",
    "Works in both Node.js and browser environments",
    "Custom randomizer support for integration with third-party RNG libraries",
    "SimpleFaker for locale-independent data generation with minimal footprint"
  ],
  "publicApiSurface": [
    "faker (default English instance)",
    "Faker (class for custom locale instances)",
    "SimpleFaker (locale-independent instance)",
    "simpleFaker (default SimpleFaker instance)",
    "faker.person — names, titles, job info",
    "faker.location — addresses, coordinates, zip codes",
    "faker.internet — emails, URLs, usernames, passwords",
    "faker.date — past/future/recent dates, birthdate",
    "faker.finance — account numbers, crypto, transactions",
    "faker.commerce — products, prices, departments",
    "faker.company — company names, buzzwords",
    "faker.string — uuid, alphanumeric, nanoid",
    "faker.number — int, float, binary, octal",
    "faker.helpers — arrayElement, multiple, fake, uniqueArray",
    "faker.lorem — words, sentences, paragraphs",
    "faker.image — avatar, url",
    "faker.color — rgb, hsl, human-readable",
    "faker.airline — flight data, airports, seats",
    "faker.animal — specific animal types",
    "faker.book — titles, authors, genres",
    "faker.database — column names, types, engines",
    "faker.food — dish names, ingredients, descriptions",
    "faker.git — commit messages, branch names",
